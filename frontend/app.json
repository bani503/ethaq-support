{
  "expo": {
    "name": "إيثاق",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.covenantapp.szevk6",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "لعرض أوقات الصلاة واتجاه القبلة بدقة"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F4C3A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.covenantapp.szevk6",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F4C3A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "لعرض أوقات الصلاة واتجاه القبلة بدقة"
        }
      ],
      "expo-audio",
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#0F4C3A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
